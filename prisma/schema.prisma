generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RegistrationAccountType {
  sole_proprietor
  company
  driver

  @@map("registration_account_type")
}

enum OrganizationType {
  sole_proprietor
  company

  @@map("organization_type")
}

enum GenderType {
  male
  female

  @@map("gender_type")
}

enum OrganizationMemberRole {
  owner
  manager
  driver

  @@map("organization_member_role")
}

enum InvitationStatus {
  pending
  accepted
  rejected
  cancelled
  expired

  @@map("invitation_status")
}

enum SectorCode {
  transport_services
  home_moving
  cargo
  logistics

  @@map("sector_code")
}

enum FreightShipmentStatus {
  draft
  active
  completed
  cancelled

  @@map("freight_shipment_status")
}

model User {
  id               String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  registrationType RegistrationAccountType @map("registration_type")
  email            String?                 @db.Citext
  phone            String
  passwordHash     String                  @map("password_hash")
  firstName        String                  @map("first_name")
  lastName         String                  @map("last_name")
  gender           GenderType?
  nationalId       String?                 @map("national_id")
  profileImageUrl           String? @map("profile_image_url")
  profileImageThumbnailUrl  String? @map("profile_image_thumbnail_url")
  emailVerifiedAt  DateTime?               @map("email_verified_at") @db.Timestamptz(6)
  phoneVerifiedAt  DateTime?               @map("phone_verified_at") @db.Timestamptz(6)
  isActive         Boolean                 @default(true) @map("is_active")
  memberCode       String?                 @unique @map("member_code") @db.Char(7)
  createdAt        DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  driverProfile            DriverProfile?
  organizationsCreated     Organization[]           @relation("OrganizationCreator")
  organizationMembers      OrganizationMember[]
  invitationsSent          OrganizationInvitation[] @relation("InvitationInviter")
  invitationsReceived      OrganizationInvitation[] @relation("InvitationTarget")
  appNotifications         AppNotification[]
  sessions                 UserSession[]
  activeOrganization       UserActiveOrganization?
  driverLocations          DriverLocation[]
  driverLocationLatest     DriverLocationLatest?
  activityDocumentsUploaded ActivityDocument[]
  pushTokens               UserPushToken[]
  driverVehicles           DriverVehicle[]
  assignedDriverVehicles   DriverVehicle[]      @relation("VehicleAssignedDriver")
  freightShipments         FreightShipment[]
  savedLocations           SavedLocation[]

  @@index([registrationType], map: "idx_users_registration_type")
  @@map("users")
}

model SavedLocation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  latitude  Float
  longitude Float
  address   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_saved_locations_user_id")
  @@index([createdAt(sort: Desc)], map: "idx_saved_locations_created_at")
  @@map("saved_locations")
}

model DriverVehicle {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  vehicleBrand   String   @map("vehicle_brand")
  vehicleModel   String   @map("vehicle_model")
  makeModel      String?  @map("make_model")
  plateVehicle   String   @map("plate_vehicle")
  plateTrailer   String?  @map("plate_trailer")
  vehicleType    String   @map("vehicle_type")
  modelYear      String   @map("model_year")
  color          String
  bodyType       String   @map("body_type")
  widthCm        String   @map("width_cm")
  lengthCm       String   @map("length_cm")
  heightCm       String   @map("height_cm")
  bodyVolumeM3   String   @map("body_volume_m3")
  tonnageKg      String   @map("tonnage_kg")
  extraInfo              String   @map("extra_info") @db.Text
  assignedDriverUserId   String?  @map("assigned_driver_user_id") @db.Uuid
  createdAt              DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedDriver User?                @relation("VehicleAssignedDriver", fields: [assignedDriverUserId], references: [id], onDelete: SetNull)
  images         DriverVehicleImage[]

  @@index([userId], map: "idx_driver_vehicles_user_id_multi")
  @@map("driver_vehicles")
}

model DriverVehicleImage {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleId     String   @map("vehicle_id") @db.Uuid
  imageUrl      String   @map("image_url")
  thumbnailUrl  String   @map("thumbnail_url")
  sortOrder     Int      @default(0) @map("sort_order")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  vehicle DriverVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId], map: "idx_driver_vehicle_images_vehicle")
  @@map("driver_vehicle_images")
}

model UserPushToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  fcmToken    String   @map("fcm_token")
  platform    String
  deviceLabel String?  @map("device_label")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fcmToken], map: "user_push_tokens_user_fcm_unique")
  @@index([userId], map: "idx_user_push_tokens_user")
  @@map("user_push_tokens")
}

model DriverProfile {
  userId      String   @id @map("user_id") @db.Uuid
  city        String
  district    String
  country     String   @default("Türkiye")
  addressLine String   @map("address_line")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("driver_profiles")
}

model Organization {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgType         OrganizationType @map("org_type")
  displayName     String           @map("display_name")
  logoUrl         String?          @map("logo_url")
  taxOffice       String           @map("tax_office")
  taxNumber       String           @unique @map("tax_number")
  landlinePhone   String?          @map("landline_phone")
  mobilePhone     String?          @map("mobile_phone")
  email           String           @db.Citext
  websiteUrl      String?          @map("website_url")
  city            String
  district        String
  country         String           @default("Türkiye")
  addressLine     String           @map("address_line")
  createdByUserId String           @map("created_by_user_id") @db.Uuid
  orgCode         String?          @unique @map("org_code") @db.Char(8)
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  createdBy        User                     @relation("OrganizationCreator", fields: [createdByUserId], references: [id])
  sectors          OrganizationSector[]
  activityDocuments ActivityDocument[]
  members          OrganizationMember[]
  invitations      OrganizationInvitation[]
  activeForUsers   UserActiveOrganization[]
  driverLocations  DriverLocation[]

  @@index([orgType], map: "idx_organizations_org_type")
  @@index([createdByUserId], map: "idx_organizations_created_by")
  @@map("organizations")
}

model OrganizationSector {
  organizationId String     @map("organization_id") @db.Uuid
  sector         SectorCode
  createdAt      DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([organizationId, sector])
  @@map("organization_sectors")
}

model ActivityDocument {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String   @map("organization_id") @db.Uuid
  documentName     String   @map("document_name")
  fileUrl          String   @map("file_url")
  fileMime         String?  @map("file_mime")
  fileSizeBytes    BigInt?  @map("file_size_bytes")
  sortOrder        Int      @default(0) @map("sort_order")
  uploadedByUserId String?  @map("uploaded_by_user_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  uploadedBy   User?        @relation(fields: [uploadedByUserId], references: [id])

  @@index([organizationId], map: "idx_activity_documents_org")
  @@map("activity_documents")
}

model OrganizationMember {
  id               String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId   String                 @map("organization_id") @db.Uuid
  userId           String                 @map("user_id") @db.Uuid
  memberRole       OrganizationMemberRole @map("member_role")
  status           InvitationStatus       @default(accepted)
  companyPosition  String?                @map("company_position")
  isSelfDriver     Boolean                @default(false) @map("is_self_driver")
  canViewLocations Boolean                @default(true) @map("can_view_locations")
  shareLocation    Boolean                @default(true) @map("share_location")
  invitedByUserId  String?                @map("invited_by_user_id") @db.Uuid
  joinedAt         DateTime?              @map("joined_at") @db.Timestamptz(6)
  createdAt        DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId, memberRole], map: "idx_organization_members_org_user_role")
  @@index([userId], map: "idx_organization_members_user")
  @@index([organizationId, status], map: "idx_organization_members_org_status")
  @@map("organization_members")
}

model UserActiveOrganization {
  userId         String   @id @map("user_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("user_active_organizations")
}

model OrganizationInvitation {
  id              String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId  String                 @map("organization_id") @db.Uuid
  invitedByUserId String                 @map("invited_by_user_id") @db.Uuid
  inviteRole      OrganizationMemberRole @default(driver) @map("invite_role")
  targetUserId    String?                @map("target_user_id") @db.Uuid
  targetPhone     String?                @map("target_phone")
  targetEmail     String?                @map("target_email") @db.Citext
  inviteCode      String                 @unique @default(dbgenerated("encode(gen_random_bytes(16), 'hex'::text)")) @map("invite_code")
  status          InvitationStatus       @default(pending)
  message         String?
  expiresAt       DateTime               @default(dbgenerated("(now() + '7 days'::interval)")) @map("expires_at") @db.Timestamptz(6)
  respondedAt     DateTime?              @map("responded_at") @db.Timestamptz(6)
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime               @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitationInviter", fields: [invitedByUserId], references: [id])
  targetUser   User?        @relation("InvitationTarget", fields: [targetUserId], references: [id])

  @@index([organizationId, status], map: "idx_org_invitations_org_status")
  @@map("organization_invitations")
}

/// LogiMap VDS in-app bildirimler (Family247 notifications karşılığı)
model AppNotification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String
  title     String
  message   String?
  data      Json     @default("{}")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)], map: "idx_app_notifications_user_created")
  @@map("app_notifications")
}

model UserSession {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  refreshTokenHash String    @map("refresh_token_hash")
  deviceLabel      String?   @map("device_label")
  ipAddress        String?   @map("ip_address")
  userAgent        String?   @map("user_agent")
  expiresAt        DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt        DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_user_sessions_user")
  @@map("user_sessions")
}

model DriverLocation {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  organizationId String? @map("organization_id") @db.Uuid
  latitude       Float
  longitude      Float
  accuracyM      Float?    @map("accuracy_m")
  speedMps       Float?    @map("speed_mps")
  headingDeg     Float?    @map("heading_deg")
  batteryPercent Int?      @map("battery_percent") @db.SmallInt
  recordedAt     DateTime  @default(now()) @map("recorded_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization? @relation(fields: [organizationId], references: [id])

  @@index([userId, recordedAt(sort: Desc)], map: "idx_driver_locations_user_recorded")
  @@map("driver_locations")
}

model DriverLocationLatest {
  userId         String   @id @map("user_id") @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  latitude       Float
  longitude      Float
  accuracyM      Float?   @map("accuracy_m")
  speedMps       Float?   @map("speed_mps")
  headingDeg     Float?   @map("heading_deg")
  batteryPercent Int?     @map("battery_percent") @db.SmallInt
  recordedAt     DateTime @map("recorded_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("driver_location_latest")
}

/// Adres otomatik tamamlama önbelleği (Places API sonuçları + koordinat).
model AddressGeocodeCache {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  placeId          String?  @unique @map("place_id")
  formattedAddress String   @map("formatted_address")
  displayLabel     String   @map("display_label")
  latitude         Float    @map("latitude")
  longitude        Float    @map("longitude")
  searchKey        String   @map("search_key")
  province         String?  @map("province")
  district         String?  @map("district")
  hitCount         Int      @default(0) @map("hit_count")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastUsedAt       DateTime @default(now()) @map("last_used_at") @db.Timestamptz(6)

  @@index([searchKey], map: "idx_address_geocode_search_key")
  @@map("address_geocode_cache")
}

/// Nakliye rota mesafesi — Google Routes sonuç önbelleği (koordinat çifti).
model RouteDistanceCache {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  routeKey             String   @unique @map("route_key")
  startProvince        String   @map("start_province")
  startDistrict        String   @map("start_district")
  endProvince          String   @map("end_province")
  endDistrict          String   @map("end_district")
  originAddress        String   @map("origin_address")
  destinationAddress   String   @map("destination_address")
  originLat            Float?   @map("origin_lat")
  originLng            Float?   @map("origin_lng")
  destinationLat       Float?   @map("destination_lat")
  destinationLng       Float?   @map("destination_lng")
  distanceMeters       Int      @map("distance_meters")
  durationSeconds      Int      @map("duration_seconds")
  encodedPolyline      String?  @map("encoded_polyline")
  hitCount             Int      @default(0) @map("hit_count")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastUsedAt           DateTime @default(now()) @map("last_used_at") @db.Timestamptz(6)

  @@index([startProvince, startDistrict, endProvince, endDistrict], map: "idx_route_cache_places")
  @@map("route_distance_cache")
}

/// Nakliye ekle sihirbazı — tam kayıt (adım 1–3).
model FreightShipment {
  id                         String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                     String                @map("user_id") @db.Uuid
  organizationId             String?               @map("organization_id") @db.Uuid
  status                     FreightShipmentStatus @default(active)
  startProvince              String                @map("start_province")
  startDistrict              String                @map("start_district")
  startAt                    DateTime              @map("start_at") @db.Timestamptz(6)
  startBreakMinutes          Int                   @default(0) @map("start_break_minutes")
  endProvince                String                @map("end_province")
  endDistrict                String                @map("end_district")
  vehicleReturnAt            DateTime              @map("vehicle_return_at") @db.Timestamptz(6)
  endRestMinutes             Int                   @default(0) @map("end_rest_minutes")
  estimatedDistanceKm        Float?                @map("estimated_distance_km")
  estimatedDurationSeconds   Int?                  @map("estimated_duration_seconds")
  estimatedRouteFromLabel    String?               @map("estimated_route_from_label")
  estimatedRouteToLabel      String?               @map("estimated_route_to_label")
  routeLegsJson              Json?                 @map("route_legs_json")
  returnStartProvince        String?               @map("return_start_province")
  returnStartDistrict        String?               @map("return_start_district")
  returnEndProvince          String?               @map("return_end_province")
  returnEndDistrict          String?               @map("return_end_district")
  returnStartBreakMinutes    Int                   @default(0) @map("return_start_break_minutes")
  returnEstimatedDistanceKm  Float?                @map("return_estimated_distance_km")
  returnEstimatedDurationSeconds Int?              @map("return_estimated_duration_seconds")
  returnEstimatedRouteFromLabel String?            @map("return_estimated_route_from_label")
  returnEstimatedRouteToLabel   String?            @map("return_estimated_route_to_label")
  returnRouteLegsJson        Json?                 @map("return_route_legs_json")
  outboundHasLoad            String?               @map("outbound_has_load")
  outboundLoadStatus         String?               @map("outbound_load_status")
  outboundCanTakeExtraLoad   String?               @map("outbound_can_take_extra_load")
  outboundLoadDescription    String?               @map("outbound_load_description") @db.Text
  outboundFillPercent        String?               @map("outbound_fill_percent")
  outboundTonnageFullness    String?               @map("outbound_tonnage_fullness")
  outboundCargoSpaceEmpty    String?               @map("outbound_cargo_space_empty")
  outboundTonnageEmpty       String?               @map("outbound_tonnage_empty")
  outboundLoadCriteria       String?               @map("outbound_load_criteria") @db.Text
  returnHasLoad              String?               @map("return_has_load")
  returnLoadStatus           String?               @map("return_load_status")
  returnLoadDescription      String?               @map("return_load_description") @db.Text
  returnCanTakeExtraLoad     String?               @map("return_can_take_extra_load")
  returnFillPercent          String?               @map("return_fill_percent")
  returnTonnageFullness      String?               @map("return_tonnage_fullness")
  returnCargoSpaceEmpty      String?               @map("return_cargo_space_empty")
  returnTonnageEmpty         String?               @map("return_tonnage_empty")
  returnOnlySameDirection    String?               @map("return_only_same_direction")
  returnLoadCriteria         String?               @map("return_load_criteria") @db.Text
  acceptedTermsAt            DateTime              @map("accepted_terms_at") @db.Timestamptz(6)
  createdAt                  DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                  DateTime              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user              User                            @relation(fields: [userId], references: [id], onDelete: Cascade)
  routeStops         FreightShipmentRouteStop[]
  returnRouteStops   FreightShipmentReturnRouteStop[]
  loadAtStops        FreightShipmentLoadAtStop[]
  surroundingLoads   FreightShipmentSurroundingLoad[]

  @@index([userId, createdAt(sort: Desc)], map: "idx_freight_shipments_user_created")
  @@index([organizationId, createdAt(sort: Desc)], map: "idx_freight_shipments_org_created")
  @@map("freight_shipments")
}

model FreightShipmentRouteStop {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipmentId   String   @map("shipment_id") @db.Uuid
  sortOrder    Int      @map("sort_order")
  province     String
  district     String
  breakMinutes Int      @default(0) @map("break_minutes")

  shipment FreightShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, sortOrder], map: "idx_freight_route_stops_shipment")
  @@map("freight_shipment_route_stops")
}

model FreightShipmentReturnRouteStop {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipmentId   String   @map("shipment_id") @db.Uuid
  sortOrder    Int      @map("sort_order")
  province     String
  district     String
  breakMinutes Int      @default(0) @map("break_minutes")

  shipment FreightShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, sortOrder], map: "idx_freight_return_route_stops_shipment")
  @@map("freight_shipment_return_route_stops")
}

model FreightShipmentLoadAtStop {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipmentId     String  @map("shipment_id") @db.Uuid
  direction      String  @map("direction")
  routeStopIndex Int     @map("route_stop_index")
  fillPercent    String? @map("fill_percent")
  tonnageKg      String? @map("tonnage_kg")
  cargoM3        String? @map("cargo_m3")
  loadCriteria   String? @map("load_criteria") @db.Text

  shipment FreightShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, direction], map: "idx_freight_load_stops_shipment")
  @@map("freight_shipment_load_at_stops")
}

model FreightShipmentSurroundingLoad {
  id         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shipmentId String @map("shipment_id") @db.Uuid
  sortOrder  Int    @map("sort_order")
  province   String
  district   String

  shipment FreightShipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, sortOrder], map: "idx_freight_surrounding_shipment")
  @@map("freight_shipment_surrounding_loads")
}

