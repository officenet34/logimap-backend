# LogiMap API — Coolify / yerel örnek (gerçek değerleri .env dosyanıza koyun)

DATABASE_URL=postgresql://user:pass@host:5432/logimap
JWT_SECRET=change-me

# Google Routes API (Flutter → VDS → Google). Anahtar YALNIZCA sunucuda.
# Google Cloud: Routes API etkin, faturalandırma açık.
# Uygulama kısıtları: YOK (Android/iOS kısıtlı harita anahtarını KULLANMAYIN — 403).
# API kısıtları: Routes API + Places API (New)
GOOGLE_ROUTES_API_KEY=
# Opsiyonel; yoksa ROUTES anahtarı Places için de kullanılır
GOOGLE_PLACES_API_KEY=
