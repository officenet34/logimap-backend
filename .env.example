# LogiMap API — Coolify / yerel örnek

DATABASE_URL=postgresql://user:pass@host:5432/logimap
JWT_SECRET=change-me

# Nakliye adres arama — Photon (OSM, ücretsiz). Varsayılan: Komoot public API.
# Kendi Photon sunucunuz: PHOTON_BASE_URL=http://127.0.0.1:2322
PHOTON_BASE_URL=https://photon.komoot.io

# Nakliye mesafe — OSRM (ücretsiz). VDS'te Docker OSRM önerilir.
# Örnek: OSRM_BASE_URL=http://osrm:5000  (Coolify iç ağ)
OSRM_BASE_URL=https://router.project-osrm.org

# Harita (Flutter) — ayrı; nakliye için Google Routes/Places GEREKMEZ.
# GOOGLE_ROUTES_API_KEY=
