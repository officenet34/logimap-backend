# Bu dosyayı GitHub'a YÜKLEMEYİN. Sadece örnek.
# Coolify'da her satırı AYRI alan olarak girin (Bulk Editor'da özel karakter kullanmayın).

NODE_ENV=production
PORT=3000

# HOST: Coolify → PostgreSQL → "Internal URL" içindeki hostname (ör. coolify-db-xxx, logimap-db DEĞİL tahmin)
DATABASE_URL=postgresql://logimap_app:SIFRE@POSTGRES_INTERNAL_HOST:5432/logimap_db

# Sadece harf ve rakam (a-z A-Z 0-9) — + ' " boşluk Türkçe harf KULLANMAYIN
JWT_ACCESS_SECRET=degistir64karakterlikrastgeleaccesssecret1234567890ab
JWT_REFRESH_SECRET=degistir64karakterlikrastgelerefreshsecret1234567890cd

JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
CORS_ORIGINS=*
